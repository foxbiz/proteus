<?xml version='1.0' encoding='utf-8'?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.App.SplashScreen" parent="Theme.SplashScreen.IconBackground">
        <item name="android:windowSplashScreenBackground" tools:ignore="NewApi">@color/splashscreen_background</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:ignore="NewApi">@drawable/splash_icon</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:ignore="NewApi">false</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Set all backgrounds to black to prevent any flash -->
        <item name="android:windowBackground">@color/splashscreen_background</item>
        <item name="android:colorBackground">@color/splashscreen_background</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- Disable window animations that cause flash -->
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowIsTranslucent">false</item>

        <!-- Ensure no flicker during navigation bar interactions -->
        <item name="android:enforceNavigationBarContrast" tools:ignore="NewApi">false</item>
        <item name="android:enforceStatusBarContrast" tools:ignore="NewApi">false</item>

        <!-- Edge-to-edge: transparent system bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
